# Neon Database
# Скопируй connection string из Neon Dashboard -> кнопка "Connect" -> вкладка "Connection string"
DATABASE_URL="postgresql://YOUR_USER:YOUR_PASSWORD@YOUR_HOST.neon.tech/neondb?sslmode=require"

# Microsoft Clarity
# Скопируй Project ID из Clarity -> Параметры (Settings) -> Overview -> Project ID
NEXT_PUBLIC_CLARITY_ID=""

# Домен сайта (поменяй когда купишь свой домен)
NEXT_PUBLIC_SITE_URL="https://orysilk.com"
